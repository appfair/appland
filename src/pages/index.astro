---
import Layout from '../layouts/Layout.astro';
import LandingPage from '../components/LandingPage.astro';
import AppGrid from '../components/AppGrid.astro';
import { loadSite } from '../lib/data.ts';
import { appPageHref, localeIndexHref, localeLinksFor } from '../lib/routes.ts';

const data = await loadSite();
const locale =
  data.locales.find((l) => l.code === data.defaultLocale) ?? data.locales[0]!;

const localeLinks = localeLinksFor(data.locales, localeIndexHref);

let pageTitle: string;
let pageDescription: string;
let sourceURL: string | undefined;
let releaseURL: string | undefined;
let socialImage: string | undefined = data.socialImage;

if (data.multiApp) {
  pageTitle = data.site.title;
  pageDescription = data.site.tagline ?? data.site.title;
} else {
  const appView = data.apps[0]!;
  const hero = appView.hero(locale.code);
  pageTitle = hero.subtitle ? `${hero.title} – ${hero.subtitle}` : hero.title;
  pageDescription = hero.subtitle || (hero.description.split('\n')[0] ?? data.site.title);
  sourceURL = appView.sourceURL;
  releaseURL = appView.releaseURL;
  socialImage = appView.socialImage ?? socialImage;
}
---

<Layout
  site={data.site}
  localeLinks={localeLinks}
  current={locale}
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  socialImage={socialImage}
  favicons={data.favicons}
  sourceURL={sourceURL}
  releaseURL={releaseURL}
  autoRedirect
>
  {data.multiApp ? (
    <AppGrid
      site={data.site}
      apps={data.apps}
      locale={locale}
      hrefFor={(slug) => appPageHref(locale.code, slug)}
    />
  ) : (
    <LandingPage site={data.site} appView={data.apps[0]!} locale={locale} />
  )}
</Layout>

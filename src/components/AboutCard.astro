---
import type { PlatformView, SiteInfo } from '../lib/types.ts';

interface Props {
  view: PlatformView;
  site: SiteInfo;
  i18n: {
    aboutHeading: string;
    versionLabel: string;
    buildLabel: string;
    bundleIdLabel: string;
    appIdLabel: string;
    privacyLink: string;
    supportLink: string;
    dependenciesLabel: string;
  };
}

const { view, site, i18n } = Astro.props;
---

<aside class="rounded-3xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-5 sm:p-6 space-y-4 shadow-lg shadow-black/5">
  <h2 class="text-lg font-semibold tracking-tight">{i18n.aboutHeading}</h2>

  <dl class="grid gap-3 text-sm">
    {view.version && (
      <div class="flex justify-between gap-3">
        <dt class="text-[color:var(--color-text-muted)]">{i18n.versionLabel}</dt>
        <dd class="font-mono">{view.version}</dd>
      </div>
    )}
    {view.buildNumber && (
      <div class="flex justify-between gap-3">
        <dt class="text-[color:var(--color-text-muted)]">{i18n.buildLabel}</dt>
        <dd class="font-mono">{view.buildNumber}</dd>
      </div>
    )}
    {view.id === 'ios' && view.permissions.length > 0 && (
      <div class="flex justify-between gap-3 items-baseline">
        <dt class="text-[color:var(--color-text-muted)]">Permissions</dt>
        <dd class="font-mono">{view.permissions.length}</dd>
      </div>
    )}
    {view.id === 'android' && view.permissions.length > 0 && (
      <div class="flex justify-between gap-3 items-baseline">
        <dt class="text-[color:var(--color-text-muted)]">Permissions</dt>
        <dd class="font-mono">{view.permissions.length}</dd>
      </div>
    )}
    {site.showDependencyCount !== false && view.dependencyCount > 0 && (
      <div class="flex justify-between gap-3 items-baseline">
        <dt class="text-[color:var(--color-text-muted)]">{i18n.dependenciesLabel}</dt>
        <dd class="font-mono">{view.dependencyCount}</dd>
      </div>
    )}
  </dl>

  {(view.privacyURL || view.supportURL) && (
    <div class="flex flex-wrap gap-2 pt-2 border-t border-[color:var(--color-border-soft)]">
      {view.privacyURL && (
        <a
          href={view.privacyURL}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1.5 text-sm text-[color:var(--color-accent)] hover:underline"
        >
          <svg viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
          </svg>
          {i18n.privacyLink}
        </a>
      )}
      {view.supportURL && (
        <a
          href={view.supportURL}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1.5 text-sm text-[color:var(--color-accent)] hover:underline"
        >
          <svg viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 11.5a8.4 8.4 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.4 8.4 0 0 1-3.8-.9L3 21l1.9-5.7a8.4 8.4 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6A8.4 8.4 0 0 1 12.5 3h.5a8.5 8.5 0 0 1 8 8z"/>
          </svg>
          {i18n.supportLink}
        </a>
      )}
    </div>
  )}
</aside>

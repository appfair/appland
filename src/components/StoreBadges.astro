---
import type { LocaleInfo, PlatformView } from '../lib/types.ts';
import { badgeLocale } from '../lib/i18n.ts';

interface Props {
  views: Partial<Record<'ios' | 'android', PlatformView | null>>;
  locale: LocaleInfo;
}

const { views, locale } = Astro.props;
const ios = views.ios;
const android = views.android;

// Per-locale badge files live under public/badges/<code>/. badgeLocale()
// resolves to a code we actually shipped for that store (with `en` as the
// final fallback), so these URLs never 404. Apple and Google have
// different destination locale sets, so each is resolved independently.
const APPLE_BADGE = `/badges/${badgeLocale(locale.code, 'apple')}/apple-app-store.svg`;
const GOOGLE_BADGE = `/badges/${badgeLocale(locale.code, 'google')}/google-play-store.svg`;
---

<div class="flex flex-wrap gap-3 items-center" data-pagefind-ignore>
  {ios?.storeURL && (
    <a
      href={ios.storeURL}
      class="inline-block transition hover:scale-[1.03] focus:outline-none focus:ring-2 focus:ring-[color:var(--color-accent)] focus:ring-offset-2 focus:ring-offset-[color:var(--color-bg)] rounded-xl"
      target="_blank"
      rel="noopener"
      aria-label="Download on the App Store"
    >
      {/*
        Apple's SVG viewBox is tight to the artwork (≈120×40), while
        Google's leaves ~50% extra "clear space" padding around the
        badge artwork. To make both badges look the same size on the
        page we render Apple a bit smaller and pad it with the same
        amount of margin Google's built-in padding produces, so the
        visible artwork heights match and the bounding boxes align.
      */}
      <img
        src={APPLE_BADGE}
        alt="Download on the App Store"
        width="120"
        height="40"
        class="h-12 sm:h-14 w-auto mx-3 my-3"
        loading="lazy"
      />
    </a>
  )}
  {android?.storeURL && (
    <a
      href={android.storeURL}
      class="inline-block transition hover:scale-[1.03] focus:outline-none focus:ring-2 focus:ring-[color:var(--color-accent)] focus:ring-offset-2 focus:ring-offset-[color:var(--color-bg)] rounded-xl"
      target="_blank"
      rel="noopener"
      aria-label="Get it on Google Play"
    >
      {/*
        Google's SVG viewBox is 155×60 — the artwork itself only fills
        ~40 of the 60 vertical units, with the rest being the "clear
        space" Google's brand guidelines require around the badge. We
        render the SVG at ~1.5× Apple's height (72/84px instead of
        48/56px) so the visible artwork matches; the surrounding
        padding inside the SVG is what the Apple badge mirrors with
        its mx-3/my-3 margins.
      */}
      <img
        src={GOOGLE_BADGE}
        alt="Get it on Google Play"
        width="155"
        height="60"
        class="h-[72px] sm:h-[84px] w-auto"
        loading="lazy"
      />
    </a>
  )}
</div>

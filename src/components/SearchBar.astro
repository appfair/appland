---
import type { LocaleInfo } from '../lib/types.ts';
import { uiStrings } from '../lib/uistrings.ts';

interface Props {
  locale: LocaleInfo;
}

const { locale } = Astro.props;
const ui = uiStrings(locale.code);
---

{/*
  Search uses Pagefind's headless API (loaded lazily on first focus) to
  keep the chrome simple: the visible input is a plain pill that mirrors
  the LanguagePicker, and results render into our own dropdown — none of
  Pagefind's default UI styles are loaded.

  In dev mode /pagefind/pagefind.js doesn't exist; the dynamic import
  fails silently and the input stays inert.
*/}
<div class="relative hidden md:block" data-search>
  <label
    class="inline-flex items-center gap-1.5 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-3 py-1.5 text-sm font-medium focus-within:border-[color:var(--color-accent)] focus-within:ring-2 focus-within:ring-[color:var(--color-accent)] transition w-44 lg:w-56"
  >
    <svg
      viewBox="0 0 24 24"
      class="size-4 shrink-0 opacity-60"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <circle cx="11" cy="11" r="7" />
      <path d="m21 21-4.3-4.3" />
    </svg>
    <input
      type="search"
      placeholder={ui.searchPlaceholder}
      aria-label={ui.searchPlaceholder}
      autocomplete="off"
      data-search-input
      class="min-w-0 flex-1 border-0 bg-transparent p-0 outline-none placeholder:text-[color:var(--color-text-muted)]"
    />
  </label>

  <div
    hidden
    data-search-results
    class="absolute end-0 top-[calc(100%+0.5rem)] z-50 w-[min(28rem,calc(100vw-2rem))] max-h-[min(70vh,32rem)] overflow-auto rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] shadow-2xl p-2"
  >
    <p data-search-message class="px-3 py-2 text-sm text-[color:var(--color-text-muted)]"></p>
    <ul data-search-list class="space-y-0.5"></ul>
  </div>

  {/* Tailwind needs to see these classes in source so they end up in the
      bundle even though the result items are constructed in JS. */}
  <template data-search-template>
    <li>
      <a
        class="block rounded-xl px-3 py-2 hover:bg-[color:var(--color-surface-2)] transition"
        data-link
      >
        <div class="text-sm font-semibold tracking-tight" data-title></div>
        <div class="mt-0.5 line-clamp-2 text-xs text-[color:var(--color-text-muted)]" data-excerpt></div>
      </a>
    </li>
  </template>
</div>

<script
  is:inline
  define:vars={{
    zeroResults: ui.searchZeroResults,
    languageCode: locale.code,
    baseURL: import.meta.env.BASE_URL,
  }}
>
  for (const shell of document.querySelectorAll('[data-search]')) {
    const input = shell.querySelector('[data-search-input]');
    const panel = shell.querySelector('[data-search-results]');
    const message = shell.querySelector('[data-search-message]');
    const list = shell.querySelector('[data-search-list]');
    const template = shell.querySelector('[data-search-template]');

    let pagefindPromise = null;
    function loadPagefind() {
      if (!pagefindPromise) {
        // Vite would otherwise transform this string at build time; the
        // /* @vite-ignore */ keeps the runtime URL intact.
        pagefindPromise = import(/* @vite-ignore */ baseURL + 'pagefind/pagefind.js')
          .catch(() => null);
      }
      return pagefindPromise;
    }

    function langMatches(lang) {
      if (!languageCode || !lang) return true;
      if (lang === languageCode) return true;
      return lang.split('-')[0] === languageCode.split('-')[0];
    }

    function showMessage(text) {
      message.textContent = text;
      message.hidden = false;
      list.innerHTML = '';
      panel.hidden = false;
    }

    function hidePanel() {
      panel.hidden = true;
      list.innerHTML = '';
      message.textContent = '';
    }

    let token = 0;
    async function runSearch() {
      const term = input.value.trim();
      const me = ++token;
      if (!term) {
        hidePanel();
        return;
      }
      const pagefind = await loadPagefind();
      if (me !== token) return;
      if (!pagefind) {
        hidePanel();
        return;
      }
      const search = await pagefind.debouncedSearch(term, 200);
      if (me !== token) return;
      if (search === null) return;
      if (search.results.length === 0) {
        showMessage(zeroResults.replace('[SEARCH_TERM]', term));
        return;
      }
      const datas = await Promise.all(
        search.results.slice(0, 8).map((r) => r.data()),
      );
      if (me !== token) return;
      const filtered = datas.filter((d) =>
        langMatches(d && d.meta && d.meta.language),
      );
      if (filtered.length === 0) {
        showMessage(zeroResults.replace('[SEARCH_TERM]', term));
        return;
      }
      list.innerHTML = '';
      for (const d of filtered) {
        const node = template.content.cloneNode(true);
        const a = node.querySelector('[data-link]');
        a.href = d.url || d.raw_url || '#';
        node.querySelector('[data-title]').textContent =
          (d.meta && d.meta.title) || a.href;
        // d.excerpt contains <mark> highlight spans — pass through as HTML.
        node.querySelector('[data-excerpt]').innerHTML = d.excerpt || '';
        list.appendChild(node);
      }
      message.hidden = true;
      panel.hidden = false;
    }

    input.addEventListener('input', runSearch);
    input.addEventListener('focus', runSearch);
    document.addEventListener('click', (e) => {
      if (!shell.contains(e.target)) hidePanel();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        hidePanel();
        input.blur();
      }
    });
  }
</script>

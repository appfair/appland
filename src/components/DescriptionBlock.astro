---
import type { PlatformView } from '../lib/types.ts';

interface Props {
  view: PlatformView;
  i18n: { aboutHeading: string; releaseNotesHeading: string };
}

const { view, i18n } = Astro.props;
---

<section class="space-y-6">
  {view.description && (
    <div class="space-y-3">
      <h2 class="text-xl sm:text-2xl font-semibold tracking-tight">{i18n.aboutHeading}</h2>
      <div class="prose-app text-base">{view.description}</div>
    </div>
  )}

  {view.releaseNotes && (
    <details class="rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-5">
      <summary class="flex items-center justify-between gap-3 font-semibold text-[color:var(--color-text-soft)] hover:text-[color:var(--color-text)] transition">
        <span class="inline-flex items-center gap-2">
          <svg viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 8v8M8 12h8M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
          </svg>
          {i18n.releaseNotesHeading}{view.version && ` (${view.version})`}
        </span>
        <svg viewBox="0 0 24 24" class="size-4 transition group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="m6 9 6 6 6-6"/>
        </svg>
      </summary>
      <div class="mt-4 prose-app text-sm">{view.releaseNotes}</div>
    </details>
  )}
</section>

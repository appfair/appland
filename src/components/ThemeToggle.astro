---
// Three-way light / auto / dark theme picker.
//
// Storage model:
//   localStorage 'appland-theme' = 'light' | 'dark'  → explicit pin
//   (absent)                                          → 'auto', follow OS
//
// The <html data-theme> attribute always reflects the *resolved* mode
// (light or dark) so CSS doesn't need to know about the auto state.
//
// Click semantics:
//   Light button → set Light
//   Dark  button → set Dark
//   Auto  button → if not in auto, enter auto; if already in auto, exit
//                  by selecting the opposite of what's currently displayed
//                  (so e.g. auto-resolved-to-dark → Light).
---

<div
  role="group"
  aria-label="Theme"
  class="inline-flex items-center rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-0.5"
>
  <button
    type="button"
    data-theme-set="light"
    data-active="false"
    aria-label="Light"
    title="Light"
    class="inline-flex items-center justify-center size-7 rounded-full text-[color:var(--color-text-muted)] hover:text-[color:var(--color-text)] data-[active=true]:bg-[color:var(--color-accent-soft)] data-[active=true]:text-[color:var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[color:var(--color-accent)] transition"
  >
    <svg viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
      <circle cx="12" cy="12" r="4" />
      <path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M5.6 18.4 7 17M17 7l1.4-1.4" />
    </svg>
  </button>
  <button
    type="button"
    data-theme-set="auto"
    data-active="false"
    aria-label="Auto (follow system)"
    title="Auto (follow system)"
    class="inline-flex items-center justify-center size-7 rounded-full text-[color:var(--color-text-muted)] hover:text-[color:var(--color-text)] data-[active=true]:bg-[color:var(--color-accent-soft)] data-[active=true]:text-[color:var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[color:var(--color-accent)] transition"
  >
    <svg viewBox="0 0 24 24" class="size-4" aria-hidden="true">
      <circle cx="12" cy="12" r="8" fill="none" stroke="currentColor" stroke-width="2" />
      <path d="M12 4a8 8 0 0 1 0 16z" fill="currentColor" />
    </svg>
  </button>
  <button
    type="button"
    data-theme-set="dark"
    data-active="false"
    aria-label="Dark"
    title="Dark"
    class="inline-flex items-center justify-center size-7 rounded-full text-[color:var(--color-text-muted)] hover:text-[color:var(--color-text)] data-[active=true]:bg-[color:var(--color-accent-soft)] data-[active=true]:text-[color:var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[color:var(--color-accent)] transition"
  >
    <svg viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
    </svg>
  </button>
</div>

<script>
  const KEY = 'appland-theme';

  type Pref = 'light' | 'dark' | 'auto';
  type Resolved = 'light' | 'dark';

  function systemTheme(): Resolved {
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function currentPref(): Pref {
    try {
      const v = localStorage.getItem(KEY);
      if (v === 'light' || v === 'dark') return v;
    } catch {}
    return 'auto';
  }

  function resolvedTheme(): Resolved {
    return document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
  }

  function setPref(pref: Pref) {
    try {
      if (pref === 'auto') localStorage.removeItem(KEY);
      else localStorage.setItem(KEY, pref);
    } catch {}
    const resolved: Resolved = pref === 'auto' ? systemTheme() : pref;
    document.documentElement.setAttribute('data-theme', resolved);
    syncActive();
  }

  function syncActive() {
    const pref = currentPref();
    for (const btn of document.querySelectorAll<HTMLButtonElement>('[data-theme-set]')) {
      const isActive = btn.dataset.themeSet === pref;
      btn.dataset.active = isActive ? 'true' : 'false';
      btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
    }
  }

  syncActive();

  for (const btn of document.querySelectorAll<HTMLButtonElement>('[data-theme-set]')) {
    btn.addEventListener('click', () => {
      const target = btn.dataset.themeSet as Pref;
      // Clicking Auto while already in auto toggles off auto by selecting
      // the opposite of whatever the browser is currently displaying — so
      // an auto-resolved-to-dark page snaps to Light.
      if (target === 'auto' && currentPref() === 'auto') {
        setPref(resolvedTheme() === 'dark' ? 'light' : 'dark');
        return;
      }
      setPref(target);
    });
  }

  // Track OS preference changes while user is in auto.
  try {
    const mql = window.matchMedia('(prefers-color-scheme: dark)');
    mql.addEventListener('change', (e) => {
      if (currentPref() === 'auto') {
        document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light');
      }
    });
  } catch {}
</script>

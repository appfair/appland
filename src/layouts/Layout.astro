---
import '../styles/global.css';
import type { FaviconPaths, LocaleInfo, LocaleLink, SiteInfo } from '../lib/types.ts';
import { pickText } from '../lib/i18n.ts';
import LanguagePicker from '../components/LanguagePicker.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Footer from '../components/Footer.astro';

interface Props {
  site: SiteInfo;
  /** All locales available on the site, with hrefs for the current page. */
  localeLinks: LocaleLink[];
  /** The locale this page is rendered in. */
  current: LocaleInfo;
  /**
   * Path of this page on the site, for the canonical URL. Defaults to the
   * locale's index path. Per-app pages pass /{locale}/apps/{slug}/.
   */
  pagePath?: string;
  pageTitle: string;
  pageDescription: string;
  socialImage?: string;
  favicons?: FaviconPaths;
  /** Optional links shown in the footer. */
  sourceURL?: string;
  releaseURL?: string;
  /**
   * If true, emit an inline script that reads `navigator.languages` and
   * redirects to the matching `/{locale}/` page. Only the bare `/` route
   * sets this to true; localized pages stay put so users can opt out of
   * auto-detection by navigating to /<their-locale>/ explicitly.
   */
  autoRedirect?: boolean;
}

const {
  site,
  localeLinks,
  current,
  pagePath,
  pageTitle,
  pageDescription,
  socialImage,
  favicons,
  sourceURL,
  releaseURL,
  autoRedirect = false,
} = Astro.props;

const path = pagePath ?? current.href;
const canonical = new URL(path, site.host).toString();
const accent = site.accentColor ?? '#3B82F6';

// Site title appears in the sticky top-bar and as a hreflang anchor; it's
// localized via pickText so siteinfo.yaml can carry either a plain string
// or a locale-keyed map.
const siteTitleText = pickText(site.title, current.code).value ?? '';

// hreflang alternates per locale, page-specific href
const alternates = localeLinks.map((l) => ({
  hrefLang: l.code,
  href: new URL(l.href, site.host).toString(),
}));

// Payload for the auto-redirect script. The locales list is deliberately
// the whole-site set; the inline script needs to be parser-friendly.
const localeCodes = localeLinks.map((l) => l.code);
const redirectPayload = JSON.stringify({
  locales: localeCodes,
  defaultLocale: current.code,
});
---

<!doctype html>
<html
  lang={current.code}
  dir={current.rtl ? 'rtl' : 'ltr'}
  data-default-theme={site.defaultTheme ?? 'system'}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="theme-color" content={accent} />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />

    {favicons && (
      <>
        <link rel="icon" type="image/png" href={favicons.icon} />
        <link rel="apple-touch-icon" href={favicons.appleTouchIcon} />
        <link rel="icon" sizes="192x192" href={favicons.pwaIcon192} />
        <link rel="icon" sizes="512x512" href={favicons.pwaIcon512} />
      </>
    )}

    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.hrefLang} href={a.href} />
    ))}
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL('/', site.host).toString()}
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    {socialImage && <meta property="og:image" content={socialImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    {socialImage && <meta name="twitter:image" content={socialImage} />}

    <style is:global define:vars={{ accent }}>
      :root { --accent: var(--accent); }
    </style>

    {site.analyticsScript && (
      <script
        is:inline
        defer
        src={site.analyticsScript}
        data-domain={site.analyticsDomain}
      ></script>
    )}

    {autoRedirect && (
      <script is:inline set:html={`
        (function () {
          try {
            var cfg = ${redirectPayload};
            var locales = cfg.locales || [];
            var nav = (typeof navigator !== 'undefined' && navigator) || {};
            var prefs = nav.languages && nav.languages.length
              ? nav.languages
              : [nav.language || ''];
            function pick(b) {
              if (!b) return null;
              var lc = String(b).toLowerCase();
              for (var i = 0; i < locales.length; i++) {
                if (String(locales[i]).toLowerCase() === lc) return locales[i];
              }
              var lang = lc.split('-')[0];
              for (var j = 0; j < locales.length; j++) {
                if (String(locales[j]).toLowerCase().split('-')[0] === lang) {
                  return locales[j];
                }
              }
              return null;
            }
            var target = null;
            for (var k = 0; k < prefs.length && !target; k++) {
              target = pick(prefs[k]);
            }
            if (target) {
              var loc = window.location;
              loc.replace('/' + target + '/' + (loc.search || '') + (loc.hash || ''));
            }
          } catch (_) { /* never block rendering */ }
        })();
      `} />
    )}

    <script is:inline>
      (function () {
        try {
          var key = 'appland-theme';
          var saved = localStorage.getItem(key);
          var def = document.documentElement.getAttribute('data-default-theme') || 'system';
          var theme = saved || def;
          if (theme === 'system') {
            var mql = window.matchMedia('(prefers-color-scheme: dark)');
            theme = mql.matches ? 'dark' : 'light';
          }
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-dvh text-[color:var(--color-text)]">
    <header
      class="sticky top-0 z-30 backdrop-blur-md bg-[color:var(--color-bg)]/70 border-b border-[color:var(--color-border-soft)]"
    >
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-3 flex items-center gap-3">
        <a
          href={current.href}
          class="font-semibold tracking-tight text-base sm:text-lg shrink-0"
        >{siteTitleText}</a>
        <div class="flex-1"></div>
        <LanguagePicker locales={localeLinks} current={current} />
        <ThemeToggle />
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-4 sm:px-6 py-8 sm:py-12">
      <slot />
    </main>

    <Footer
      site={site}
      locale={current}
      sourceURL={sourceURL}
      releaseURL={releaseURL}
    />
  </body>
</html>
